{% extends 'base.html.twig' %}

{% block title %}Inicio | Gusmuss Diamond{% endblock %}

{% block body %}
<style>
    .hero-section {
        text-align: center;
        padding: 100px 20px;
        background-color: #fcf9f9;
        font-family: 'Didot', 'Georgia', serif;
        min-height: 80vh;
    }
    .titulo-lujo {
        color: #1a1a1a;
        font-size: 3.5rem;
        letter-spacing: 2px;
        text-transform: uppercase;
        margin-bottom: 20px;
    }
    .subtitulo {
        color: #666;
        font-size: 1.2rem;
        font-style: italic;
    }
</style>

<div class="hero-section">
    <h1 class="titulo-lujo">Gusmuss Diamond</h1>
    <p class="subtitulo">La elegancia no es destacar, es ser recordada.</p>
</div>
{% endblock %}