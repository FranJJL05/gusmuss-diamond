<!DOCTYPE html>
<html lang="es">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>{% block title %}Gusmuss Diamond{% endblock %}</title>
        
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
        
        {% block stylesheets %}{% endblock %}
        {% block javascripts %}{% endblock %}
    </head>
    <body class="bg-light">
        
        <nav class="navbar navbar-expand-lg navbar-light bg-white shadow-sm py-3">
          <div class="container">
            <a class="navbar-brand text-uppercase fw-bold" href="/" style="font-family: 'Didot', serif; font-size: 1.5rem;">
                Gusmuss Diamond
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#menuPrincipal">
              <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse justify-content-end" id="menuPrincipal">
              <ul class="navbar-nav ms-auto mb-2 mb-lg-0">
                    <li class="nav-item">
                        <a class="nav-link active" href="{{ path('app_home') }}">Inicio</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="#">Colección</a>
                    </li>
                    
                    {# Magia de Symfony: Comprobamos si el usuario ha iniciado sesión #}
                    {% if app.user %}
                        <li class="nav-item">
                            <a class="nav-link" href="#">Mi Cuenta ({{ app.user.nombre }})</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-danger" href="{{ path('app_logout') }}">Cerrar Sesión</a>
                        </li>
                    {% else %}
                        <li class="nav-item">
                            <a class="nav-link" href="{{ path('app_login') }}">Iniciar Sesión</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="{{ path('app_register') }}">Registrarse</a>
                        </li>
                    {% endif %}
                </ul>
            </div>
          </div>
        </nav>

        <main>
            {% block body %}{% endblock %}
        </main>

        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    </body>
</html>